# ============================================================
# Agentic Investment OS — Environment Variables
# Скопируй в .env и заполни свои значения
# ============================================================

# === Database ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=investor
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=investment_os

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === LLM (g4f — ChatGPT через reverse proxy) ===
LLM_PROVIDER=g4f
LLM_MODEL=gpt-4o
# Fallback модель если основная недоступна
LLM_FALLBACK_MODEL=gpt-4o-mini

# === Pipeline Settings ===
# Частота запуска в часах (по умолчанию каждые 6 часов)
PIPELINE_INTERVAL_HOURS=6
# Максимум новостей на один прогон
MAX_NEWS_PER_RUN=50
# Глубина анализа в днях
ANALYSIS_DEPTH_DAYS=7

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=logs/investment_os.log
