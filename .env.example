# ============================================================
# Agentic Investment OS — Environment Variables
# Скопируй в .env и заполни свои значения
# ============================================================

# === Database ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=investor
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=investment_os

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === Browser (Playwright / ChatGPT Plus Web / Gemini) ===
# Путь к папке с профилем Chromium (хранит сессию ChatGPT Plus)
# На Ubuntu-сервере: /app/.browser_data (или абсолютный путь)
BROWSER_DATA_PATH=.browser_data
# Headless-режим: True для сервера, False для первичной настройки на десктопе
BROWSER_HEADLESS=True
# URL-ссылка на ваш существующий чат Smeam в Gemini (скопируйте из строки браузера)
GEMINI_CHAT_URL=https://gemini.google.com/app/xxxxxxxxxxxx

# === Pipeline Settings ===
# Частота запуска в часах (по умолчанию каждые 6 часов)
PIPELINE_INTERVAL_HOURS=6
# Максимум новостей на один прогон
MAX_NEWS_PER_RUN=50
# Глубина анализа в днях
ANALYSIS_DEPTH_DAYS=7

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=logs/investment_os.log
